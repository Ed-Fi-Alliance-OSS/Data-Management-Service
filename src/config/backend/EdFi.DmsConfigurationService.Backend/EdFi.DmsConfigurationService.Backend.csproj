<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>
    <ItemGroup>
        <AssemblyAttribute Include="System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverageAttribute" />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="JsonSchema.Net" />
        <PackageReference Include="Microsoft.AspNetCore.Http.Abstractions" />
        <PackageReference Include="Microsoft.Extensions.Logging" />
        <PackageReference Include="Microsoft.Extensions.Options" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\..\datamodel\EdFi.DmsConfigurationService.DataModel\EdFi.DmsConfigurationService.DataModel.csproj" />
    </ItemGroup>
    <ItemGroup>
        <EmbeddedResource Include="Claims/JsonSchemaForClaims.json" />
        <!-- Per-data-standard embedded base claims. Adding a DS version is dropping a
             Claims/Standards/ds<NN>/Claims.json folder; the version is selected at runtime. -->
        <EmbeddedResource Include="Claims/Standards/**/Claims.json" />
    </ItemGroup>
</Project>
