# DMS-1078: ApiClient POST and reset-credential response fields
#
# Demonstrates that POST /v2/apiClients now returns `name` and `applicationId`,
# and PUT /v2/apiClients/{id}/reset-credential also returns them.
#
# Prerequisites (local dev setup):
#   1. Copy `eng/docker-compose/.env.e2e` to `eng/docker-compose/.env`
#   2. Run `eng/docker-compose/start-all-services.ps1`
#   3. Run `eng/docker-compose/start-keycloak.ps1`
#   4. Run `eng/docker-compose/setup-keycloak.ps1`
#   5. Run DMS Configuration Service (appsettings.Development.json configured for local dev)
#
# Run steps from top to bottom.

@configPort = 5126
@sysAdminId = sys-admin
@encodedSysAdminSecret = SdfH%2998%26JkSdfH%2998%26JkSdfH%2998%26JkSdfH)9

# ---------------------------------------------------------------------------
# 1. Authenticate — get an admin token
# ---------------------------------------------------------------------------

### Register system administrator (only needed once)
POST http://localhost:{{configPort}}/connect/register
Content-Type: application/x-www-form-urlencoded

ClientId={{sysAdminId}}
&ClientSecret={{encodedSysAdminSecret}}
&DisplayName=System Administrator

### Get admin token
# @name configTokenRequest
POST http://localhost:{{configPort}}/connect/token
Content-Type: application/x-www-form-urlencoded

client_id={{sysAdminId}}
&client_secret={{encodedSysAdminSecret}}
&grant_type=client_credentials
&scope=edfi_admin_api/full_access

###
@configToken = {{configTokenRequest.response.body.access_token}}

# ---------------------------------------------------------------------------
# 2. Create prerequisites: vendor, DMS instance, application
# ---------------------------------------------------------------------------

### Create a vendor
# @name createVendor
POST http://localhost:{{configPort}}/v2/vendors
Content-Type: application/json
Authorization: bearer {{configToken}}

{
    "company": "DMS-1078 Demo Vendor",
    "contactName": "Test Contact",
    "contactEmailAddress": "test@example.com",
    "namespacePrefixes": "uri://ed-fi.org"
}

###
@vendorId = {{createVendor.response.body.id}}

### Create a DMS instance
# @name createDmsInstance
POST http://localhost:{{configPort}}/v2/dmsInstances
Content-Type: application/json
Authorization: bearer {{configToken}}

{
    "instanceType": "Test",
    "instanceName": "DMS-1078 Test Instance",
    "connectionString": "host=dms-postgresql;port=5432;username=postgres;password=abcdefgh1!;database=edfi_datamanagementservice;"
}

###
@dmsInstanceId = {{createDmsInstance.response.body.id}}

### Create an application
# @name createApplication
POST http://localhost:{{configPort}}/v2/applications
Content-Type: application/json
Authorization: bearer {{configToken}}

{
    "vendorId": {{vendorId}},
    "applicationName": "DMS-1078 Demo Application",
    "claimSetName": "E2E-NameSpaceBasedClaimSet",
    "dmsInstanceIds": [{{dmsInstanceId}}]
}

###
@applicationId = {{createApplication.response.body.id}}

# ---------------------------------------------------------------------------
# 3. POST /v2/apiClients — DMS-1078: response now includes name + applicationId
# ---------------------------------------------------------------------------

### Create an API client
# Expected 201 response now includes:
#   id, applicationId, name, key, secret
# @name createApiClient
POST http://localhost:{{configPort}}/v2/apiClients
Content-Type: application/json
Authorization: bearer {{configToken}}

{
    "applicationId": {{applicationId}},
    "name": "DMS-1078 Test Client",
    "isApproved": true,
    "dmsInstanceIds": [{{dmsInstanceId}}]
}

###
@apiClientId = {{createApiClient.response.body.id}}
@clientKey   = {{createApiClient.response.body.key}}
@clientSecret = {{createApiClient.response.body.secret}}

# Verify the response contains name and applicationId:
# createApiClient.response.body.name          → "DMS-1078 Test Client"
# createApiClient.response.body.applicationId → {{applicationId}}
# createApiClient.response.body.key           → (uuid string)
# createApiClient.response.body.secret        → (generated secret)

# ---------------------------------------------------------------------------
# 4. GET /v2/apiClients — verify name is present in list response
# ---------------------------------------------------------------------------

### List all API clients — each object includes the name field
GET http://localhost:{{configPort}}/v2/apiClients?offset=0&limit=25
Authorization: bearer {{configToken}}

### Get a specific API client by clientId — name is present
GET http://localhost:{{configPort}}/v2/apiClients/{{clientKey}}
Authorization: bearer {{configToken}}

# ---------------------------------------------------------------------------
# 5. PUT /v2/apiClients/{id}/reset-credential
#    DMS-1078: response now includes name + applicationId
# ---------------------------------------------------------------------------

### Reset credentials
# Expected 200 response now includes:
#   id, applicationId, name, key, secret
# @name resetCredentials
PUT http://localhost:{{configPort}}/v2/apiClients/{{apiClientId}}/reset-credential
Content-Type: application/json
Authorization: bearer {{configToken}}

{}

# Verify the response contains name and applicationId:
# resetCredentials.response.body.name          → "DMS-1078 Test Client"
# resetCredentials.response.body.applicationId → {{applicationId}}
# resetCredentials.response.body.key           → {{clientKey}}  (unchanged)
# resetCredentials.response.body.secret        → (new generated secret)

# ---------------------------------------------------------------------------
# 6. Cleanup
# ---------------------------------------------------------------------------

### Delete the API client
DELETE http://localhost:{{configPort}}/v2/apiClients/{{apiClientId}}
Authorization: bearer {{configToken}}

### Delete the application
DELETE http://localhost:{{configPort}}/v2/applications/{{applicationId}}
Authorization: bearer {{configToken}}

### Delete the DMS instance
DELETE http://localhost:{{configPort}}/v2/dmsInstances/{{dmsInstanceId}}
Authorization: bearer {{configToken}}

### Delete the vendor
DELETE http://localhost:{{configPort}}/v2/vendors/{{vendorId}}
Authorization: bearer {{configToken}}
