# DMS-1075: DMS Instances and Derivatives Encrypted Connection String Test
#
# This file exercises the /v3/dataStores and /v3/dataStoreDerivatives
# CMS endpoints. As of DMS-1075, GET responses return the connectionString
# field as a Base64-encoded AES-encrypted value rather than plain text.
# Callers should expect the connectionString in GET responses to be an
# opaque Base64 string, not the original plain-text value.
#
# Prerequisites:
# - Configuration Service running at localhost:8081 (update configPort if needed)
# - System administrator credentials registered (run register step if needed)

@configPort=8081
@sysAdminId=sys-admin
@sysAdminSecret=SdfH)98&JkSdfH)98&JkSdfH)98&JkSdfH)9
@encodedSysAdminSecret=SdfH%2998%26JkSdfH%2998%26JkSdfH%2998%26JkSdfH)9

###############################################################################
# STEP 1: Register system administrator (skip if already registered)
###############################################################################

### Register system administrator
POST http://localhost:{{configPort}}/connect/register
Content-Type: application/x-www-form-urlencoded

ClientId={{sysAdminId}}
&ClientSecret={{encodedSysAdminSecret}}
&DisplayName=System Administrator

###############################################################################
# STEP 2: Get a CMS token (OAuth2 client credentials)
###############################################################################

### Get CMS access token
# @name configTokenRequest
POST http://localhost:{{configPort}}/connect/token
Content-Type: application/x-www-form-urlencoded

client_id={{sysAdminId}}
&client_secret={{encodedSysAdminSecret}}
&grant_type=client_credentials
&scope=edfi_admin_api/full_access

###
@configToken={{configTokenRequest.response.body.access_token}}

###############################################################################
# STEP 3: Create a DMS instance with a plain-text connection string
# The POST body accepts plain text; on GET the connectionString is encrypted.
###############################################################################

### Create a DMS instance
# @name createDataStore
POST http://localhost:{{configPort}}/v3/dataStores
Content-Type: application/json
Authorization: bearer {{configToken}}

{
    "dataStoreType": "Production",
    "name": "DMS-1075 Test Instance",
    "connectionString": "host=dms-postgresql;port=5432;username=postgres;password=abcdefgh1!;database=edfi_datamanagementservice;"
}

###
@dataStoreId={{createDataStore.response.body.id}}

###############################################################################
# STEP 4: GET /v3/dataStores — list all instances
# Expected: connectionString values are Base64-encoded AES-encrypted (DMS-1075).
# The connectionString will NOT match the plain-text value sent in POST.
###############################################################################

### List all DMS instances
GET http://localhost:{{configPort}}/v3/dataStores
Authorization: bearer {{configToken}}

###############################################################################
# STEP 5: GET /v3/dataStores/{id} — get a single instance by ID
# Expected: connectionString is Base64-encoded AES-encrypted (DMS-1075).
###############################################################################

### Get DMS instance by ID
GET http://localhost:{{configPort}}/v3/dataStores/{{dataStoreId}}
Authorization: bearer {{configToken}}

###############################################################################
# STEP 6: Create a DMS instance derivative with a plain-text connection string
###############################################################################

### Create a DMS instance derivative (ReadReplica)
# @name createDataStoreDerivative
POST http://localhost:{{configPort}}/v3/dataStoreDerivatives
Content-Type: application/json
Authorization: bearer {{configToken}}

{
    "dataStoreId": {{dataStoreId}},
    "derivativeType": "ReadReplica",
    "connectionString": "host=dms-postgresql-replica;port=5432;username=postgres;password=abcdefgh1!;database=edfi_datamanagementservice_replica;"
}

###
@dataStoreDerivativeId={{createDataStoreDerivative.response.body.id}}

###############################################################################
# STEP 7: GET /v3/dataStoreDerivatives — list all derivatives
# Expected: connectionString values are Base64-encoded AES-encrypted (DMS-1075).
###############################################################################

### List all DMS instance derivatives
GET http://localhost:{{configPort}}/v3/dataStoreDerivatives
Authorization: bearer {{configToken}}

###############################################################################
# STEP 8: GET /v3/dataStoreDerivatives/{id} — get a single derivative by ID
# Expected: connectionString is Base64-encoded AES-encrypted (DMS-1075).
###############################################################################

### Get DMS instance derivative by ID
GET http://localhost:{{configPort}}/v3/dataStoreDerivatives/{{dataStoreDerivativeId}}
Authorization: bearer {{configToken}}

###############################################################################
# STEP 9: DELETE /v3/dataStoreDerivatives/{id} — clean up derivative
###############################################################################

### Delete DMS instance derivative
DELETE http://localhost:{{configPort}}/v3/dataStoreDerivatives/{{dataStoreDerivativeId}}
Authorization: bearer {{configToken}}

###############################################################################
# STEP 10: DELETE /v3/dataStores/{id} — clean up instance
###############################################################################

### Delete DMS instance
DELETE http://localhost:{{configPort}}/v3/dataStores/{{dataStoreId}}
Authorization: bearer {{configToken}}
