  "schoolId": {{school2}},
  "nameOfInstitution": "DMS-1074 School 2",
  "educationOrganizationCategories": [
    { "educationOrganizationCategoryDescriptor": "uri://ed-fi.org/EducationOrganizationCategoryDescriptor#DMS-1074 School" }
