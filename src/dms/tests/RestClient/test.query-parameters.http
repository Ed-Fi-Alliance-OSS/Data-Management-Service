### DMS-1074 - Query parameter validation and relational query smoke tests
#
# Prereqs:
#   1. Start the local DMS stack. For relational backend validation, use the same setup
#      as the DMS E2E tests.
#   2. Execute this file from top to bottom with the VS Code REST Client extension.
#
# This file follows getting-started.http for authentication:
#   - mint a Configuration Service token
#   - create a vendor, DMS instance, and application
#   - check DMS discovery
#   - mint a DMS bearer token from the Configuration Service with HTTP Basic auth
#
# Seed data is inserted through the DMS endpoints so paging, totalCount, and
# property filters can be validated against known records.
#
# Note: this file intentionally does not call DMS /management/reload-claimsets.
# That endpoint is optional and returns 404 when management endpoints are disabled
# or when multitenancy requires a tenant route. Application credential creation
# does not require a claimset reload.

@dmsPort=8080
@configPort=8081

@sysAdminId=DmsConfigurationService
@sysAdminSecret=ValidClientSecret1234567890!Abcd

# DB + password match eng/docker-compose/.env by default.
# If you started with .env.e2e.relational, change this to edfi_datamanagementservice_relational.
@dmsDatabaseName=edfi_datamanagementservice
@postgresPassword=abcdefgh1!

# Static IDs make expected query results easy to inspect. If a prior run left data
# behind, teardown/setup the dms-local stack before rerunning.
@school1=1074101
@school2=1074102
@school3=1074103
@school4=1074104
@school5=1074105
@student1=DMS1074-001
@student2=DMS1074-002

# -----------------------------------------------------------------------------
# 1. Bootstrap auth and DMS application
# -----------------------------------------------------------------------------

### 1.1 Configuration-Service token
# @name configTokenRequest
POST http://localhost:{{configPort}}/connect/token
Content-Type: application/x-www-form-urlencoded

client_id={{sysAdminId}}
&client_secret={{sysAdminSecret}}
&grant_type=client_credentials
&scope=edfi_admin_api/full_access

###
@configToken={{configTokenRequest.response.body.access_token}}

### 1.2 Create a vendor scoped to the ed-fi namespace
# @name createVendor
POST http://localhost:{{configPort}}/v2/vendors
Content-Type: application/json
Authorization: bearer {{configToken}}

{
  "company": "DMS-1074 Query Parameter Vendor {{$randomInt 0 9999999}}",
  "contactName": "Query Parameter Tester",
  "contactEmailAddress": "dms1074@example.com",
  "namespacePrefixes": "uri://ed-fi.org"
}

###
@vendorId={{createVendor.response.body.id}}

### 1.3 Create a DMS instance pointing at the relational database
# @name createDmsInstance
POST http://localhost:{{configPort}}/v2/dmsInstances
Content-Type: application/json
Authorization: bearer {{configToken}}

{
  "instanceType": "Test",
  "instanceName": "DMS-1074 Query Parameters",
  "connectionString": "host=dms-postgresql;port=5432;username=postgres;password={{postgresPassword}};database={{dmsDatabaseName}};NoResetOnClose=true;"
}

###
@dmsInstanceId={{createDmsInstance.response.body.id}}

### 1.4 Create an application with broad E2E access
# @name createApplication
POST http://localhost:{{configPort}}/v2/applications
Content-Type: application/json
Authorization: bearer {{configToken}}

{
  "vendorId": {{vendorId}},
  "applicationName": "DMS-1074 Query Parameters",
  "claimSetName": "E2E-NoFurtherAuthRequiredClaimSet",
  "educationOrganizationIds": [ {{school1}}, {{school2}}, {{school3}}, {{school4}}, {{school5}} ],
  "dmsInstanceIds": [ {{dmsInstanceId}} ]
}

###
@clientId={{createApplication.response.body.key}}
@clientSecret={{createApplication.response.body.secret}}

### 1.5 DMS discovery / service check
# @name discovery
GET http://localhost:{{dmsPort}}

###
@dataApi={{discovery.response.body.urls.dataManagementApi}}

### 1.6 DMS token
# Use the Configuration Service token endpoint directly instead of the DMS
# /oauth/token proxy. The proxy forwards to this upstream, but local stacks can
# return 502 when AppSettings__AuthenticationService is pointed at an unavailable
# upstream. The issued token is still valid for DMS because the application was
# created through CMS and DMS validates the same issuer.
# @name dmsTokenRequest
POST http://localhost:{{configPort}}/connect/token
Authorization: basic {{clientId}}:{{clientSecret}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials

###
@dmsToken={{dmsTokenRequest.response.body.access_token}}

# -----------------------------------------------------------------------------
# 2. Seed descriptors and resources through DMS endpoints
# -----------------------------------------------------------------------------

### 2.1 Grade level descriptor used by all schools
POST {{dataApi}}/ed-fi/gradeLevelDescriptors
Authorization: bearer {{dmsToken}}
Content-Type: application/json

{
  "namespace": "uri://ed-fi.org/GradeLevelDescriptor",
  "codeValue": "DMS-1074 Grade",
  "shortDescription": "DMS-1074 Grade"
}

### 2.2 Education organization category descriptor used by all schools
POST {{dataApi}}/ed-fi/educationOrganizationCategoryDescriptors
Authorization: bearer {{dmsToken}}
Content-Type: application/json

{
  "namespace": "uri://ed-fi.org/EducationOrganizationCategoryDescriptor",
  "codeValue": "DMS-1074 School",
  "shortDescription": "DMS-1074 School"
}

### 2.3 School 1
POST {{dataApi}}/ed-fi/schools
Authorization: bearer {{dmsToken}}
Content-Type: application/json

{
  "schoolId": {{school1}},
  "nameOfInstitution": "DMS-1074 School 1",
  "educationOrganizationCategories": [
    { "educationOrganizationCategoryDescriptor": "uri://ed-fi.org/EducationOrganizationCategoryDescriptor#DMS-1074 School" }
  ],
  "gradeLevels": [
    { "gradeLevelDescriptor": "uri://ed-fi.org/GradeLevelDescriptor#DMS-1074 Grade" }
  ]
}

### 2.4 School 2
POST {{dataApi}}/ed-fi/schools
Authorization: bearer {{dmsToken}}
