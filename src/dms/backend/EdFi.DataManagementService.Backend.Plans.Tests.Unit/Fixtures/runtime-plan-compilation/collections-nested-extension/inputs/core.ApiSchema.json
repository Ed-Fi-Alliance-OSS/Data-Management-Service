{
  "apiSchemaVersion": "1.0.0",
  "projectSchema": {
    "projectName": "Ed-Fi",
    "projectEndpointName": "ed-fi",
    "projectVersion": "5.0.0",
    "resourceSchemas": {
      "schools": {
        "resourceName": "School",
        "isDescriptor": false,
        "isResourceExtension": false,
        "isSubclass": false,
        "allowIdentityUpdates": false,
        "arrayUniquenessConstraints": [
          {
            "paths": [
              "$.addresses[*].city"
            ],
            "nestedConstraints": [
              {
                "basePath": "$.addresses[*]",
                "paths": [
                  "$.periods[*].periodName"
                ]
              }
            ]
          }
        ],
        "identityJsonPaths": [
          "$.schoolId"
        ],
        "documentPathsMapping": {
          "SchoolId": {
            "isReference": false,
            "isPartOfIdentity": true,
            "isRequired": true,
            "path": "$.schoolId"
          },
          "NameOfInstitution": {
            "isReference": false,
            "isPartOfIdentity": false,
            "isRequired": false,
            "path": "$.nameOfInstitution"
          },
          "AddressCity": {
            "isReference": false,
            "isPartOfIdentity": false,
            "isRequired": false,
            "path": "$.addresses[*].city"
          },
          "AddressPeriodName": {
            "isReference": false,
            "isPartOfIdentity": false,
            "isRequired": false,
            "path": "$.addresses[*].periods[*].periodName"
          }
        },
        "equalityConstraints": [],
        "jsonSchemaForInsert": {
          "type": "object",
          "properties": {
            "schoolId": {
              "type": "integer"
            },
            "nameOfInstitution": {
              "type": "string",
              "maxLength": 75
            },
            "addresses": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "city": {
                    "type": "string",
                    "maxLength": 30
                  },
                  "periods": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "periodName": {
                          "type": "string",
                          "maxLength": 30
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "required": [
            "schoolId"
          ]
        }
      }
    }
  }
}
