{
  "AllowedHosts": "*",
  "AppSettings": {
    "AllowIdentityUpdateOverrides": "",
    "ApiSchemaPath": "",
    "AuthenticationService": "http://localhost:5126/connect/token",
    "BypassTypeCoercion": false,
    "CorrelationIdHeader": "",
    "Datastore": "postgresql",
    "DomainsExcludedFromOpenApi": "",
    "EnableClaimsetReload": false,
    "EnableManagementEndpoints": false,
    "MaskRequestBodyInLogs": true,
    "MaximumPageSize": 500,
    "MaxRequestBodySizeMegabytes": 10,
    "PathBase": "",
    "RouteQualifierSegments": "",
    "UseApiSchemaPath": false,
    "ReverseProxy": {
      "UseForwardedHeaders": false,
      "KnownProxies": "",
      "KnownNetworks": ""
    },
    "MultiTenancy": false
  },
  "CircuitBreaker": {
    "BreakDurationSeconds": 30,
    "FailureRatio": 0.01,
    "MinimumThroughput": 2,
    "SamplingDurationSeconds": 10
  },
  "DeadlockRetry": {
    "MaxRetryAttempts": 3,
    "BaseDelayMilliseconds": 150,
    "UseJitter": true
  },
  "CacheSettings": {
    "ClaimSetsCacheExpirationSeconds": 600,
    "ApplicationContextCacheExpirationSeconds": 600,
    "TokenCacheExpirationSeconds": 1500,
    "ProfileCacheExpirationSeconds": 1800,
    "DataStoreCacheRefreshEnabled": true,
    "DataStoreCacheExpirationSeconds": 600
  },
  "ConfigurationServiceSettings": {
    "BaseUrl": "http://localhost:5126",
    "ClientId": "CMSReadOnlyAccess",
    "ClientSecret": "",
    "Scope": "edfi_admin_api/readonly_access",
    "EncryptionKey": ""
  },
  "Cors": {
    "SwaggerUIOrigin": "http://localhost:8082"
  },
  "DatabaseOptions": {
    "IsolationLevel": "ReadCommitted"
  },
  "MappingPacks": {
    "Enabled": false,
    "Required": false,
    "RootPath": null,
    "AllowRuntimeCompileFallback": true,
    "FailureCooldownSeconds": 0,
    "CacheMode": "InMemory"
  },
  "JwtAuthentication": {
    "Audience": "account",
    "Authority": "http://localhost:5126",
    "AutomaticRefreshIntervalHours": 24,
    "ClientRole": "service",
    "ClockSkewSeconds": 30,
    "MetadataAddress": "http://localhost:5126/.well-known/openid-configuration",
    "RefreshIntervalMinutes": 60,
    "RequireHttpsMetadata": false,
    "RoleClaimType": "role"
  },
  "RateLimit": {
    "PermitLimit": 5000,
    "QueueLimit": 0,
    "Window": 10
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Sinks.Console"
    ],
    "WriteTo": [
      {
        "Args": {
          "path": "./logs/.log",
          "rollingInterval": "Day",
          "formatter": {
            "type": "Serilog.Formatting.Json.JsonFormatter, Serilog"
          }
        },
        "Name": "File"
      },
      {
        "Args": {
          "formatter": {
            "type": "Serilog.Formatting.Json.JsonFormatter, Serilog",
            "renderMessage": true
          }
        },
        "Name": "Console"
      }
    ]
  }
}
