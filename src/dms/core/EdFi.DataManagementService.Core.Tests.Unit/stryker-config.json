{
  "stryker-config": {
    "solution": "../../EdFi.DataManagementService.sln",
    "project": "EdFi.DataManagementService.Core.csproj",
    "configuration": "Release",
    "target-framework": "net10.0",
    "reporters": ["html", "json", "progress"],
    "thresholds": {
      "high": 0,
      "low": 0,
      "break": 0
    },
    "mutate": [
      "Handler/**/*.cs",
      "Middleware/**/*.cs",
      "Response/**/*.cs",
      "Security/**/*.cs",
      "Validation/**/*.cs",
      "!**/Properties/AssemblyInfo.cs",
      "!**/bin/**",
      "!**/obj/**"
    ]
  }
}
