{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "dotnet-format-staged-files",
      "command": "dotnet",
      "args": [
        "tool",
        "run",
        "csharpier",
        "format",
        "${staged}"
      ],
      "include": [
        "**/*.cs"
      ]
    },
    {
      "name": "powershell-analyze-staged-files",
      "command": "pwsh",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "eng/Invoke-StagedPowerShellAnalysis.ps1",
        "${staged}"
      ],
      "include": [
        "**/*.ps1",
        "**/*.psm1",
        "**/*.psd1"
      ]
    }
  ]
}
