# Relational Authorization Demo
#
# This demo is based on recent authorization work in:
# reference/design/backend-redesign/epics/14-authorization/EPIC.md
#
# Start from a clean relational E2E Docker environment before using this file:
#
# cd src/dms/tests/EdFi.DataManagementService.Tests.E2E
# pwsh ./teardown-local-dms.ps1
# pwsh ./setup-local-dms.ps1 -EnvironmentFile ./.env.e2e.relational
# cd /home/brad/work/dms-root/DMS-1206
# pwsh ./eng/docker-compose/provision-relational-e2e-database.ps1 -EnvironmentFile './eng/docker-compose/.env.e2e.relational' -Configuration Release
# docker restart dms-local-dms-1
#
#
# Run this file once against that freshly provisioned relational database. Before rerunning,
# perform the full teardown/setup/provision sequence again because this file uses fixed demo
# IDs and captured Location headers.

@configPort=8081
@dmsPort=8080
@dmsInstanceDatabase=edfi_datamanagementservice_relational
# httpYac runs on the host, where Docker service names like dms-config-service do not resolve.
@tokenUrl=http://localhost:{{configPort}}/connect/token

@sysAdminId=sys-admin
@sysAdminSecret=SdfH)98&JkSdfH)98&JkSdfH)98&JkSdfH)9
@encodedSysAdminSecret=SdfH%2998%26JkSdfH%2998%26JkSdfH%2998%26JkSdfH)9

#
# Preparation: CMS administrator, discovery, DMS instance, clients, and tokens.
# Run this preparation block before the live demo.
#

### Register the system administrator credentials
# If this administrator already exists, continue with the token request.
POST http://localhost:{{configPort}}/connect/register
Content-Type: application/x-www-form-urlencoded

ClientId={{sysAdminId}}
&ClientSecret={{encodedSysAdminSecret}}
&DisplayName=System Administrator

### Create a CMS administrator token
# @name configTokenRequest
POST http://localhost:{{configPort}}/connect/token
Content-Type: application/x-www-form-urlencoded

client_id={{sysAdminId}}
&client_secret={{encodedSysAdminSecret}}
&grant_type=client_credentials
&scope=edfi_admin_api/full_access

### Read the DMS discovery document
# @name discovery
GET http://localhost:{{dmsPort}}

### Create the relational DMS instance used by all demo applications
# @name createDmsInstance
POST http://localhost:{{configPort}}/v2/dmsInstances
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "instanceType": "Test",
    "instanceName": "Authorization Relational Demo",
    "connectionString": "host=dms-postgresql;port=5432;username=postgres;password=abcdefgh1!;database={{dmsInstanceDatabase}};"
}

### Create the Ed-Fi and TPDM namespace vendor for EdOrg and people tokens
# @name createEdFiVendor
POST http://localhost:{{configPort}}/v2/vendors
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "company": "Authorization Demo Ed-Fi Vendor",
    "contactName": "Authorization Demo",
    "contactEmailAddress": "authorization-demo-edfi@example.com",
    "namespacePrefixes": "uri://ed-fi.org,uri://tpdm.ed-fi.org"
}

{{
  exports.edFiVendorLocation = response.headers.location;
}}

### Retrieve the Ed-Fi vendor id
# @name getEdFiVendor
GET {{edFiVendorLocation}}
Authorization: Bearer {{configTokenRequest.access_token}}

### Create the ns2 namespace vendor
# @name createNs2Vendor
POST http://localhost:{{configPort}}/v2/vendors
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "company": "Authorization Demo NS2 Vendor",
    "contactName": "Authorization Demo",
    "contactEmailAddress": "authorization-demo-ns2@example.com",
    "namespacePrefixes": "uri://ns2.org"
}

{{
  exports.ns2VendorLocation = response.headers.location;
}}

### Retrieve the ns2 vendor id
# @name getNs2Vendor
GET {{ns2VendorLocation}}
Authorization: Bearer {{configTokenRequest.access_token}}

### Create the ns3 namespace vendor
# @name createNs3Vendor
POST http://localhost:{{configPort}}/v2/vendors
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "company": "Authorization Demo NS3 Vendor",
    "contactName": "Authorization Demo",
    "contactEmailAddress": "authorization-demo-ns3@example.com",
    "namespacePrefixes": "uri://ns3.org"
}

{{
  exports.ns3VendorLocation = response.headers.location;
}}

### Retrieve the ns3 vendor id
# @name getNs3Vendor
GET {{ns3VendorLocation}}
Authorization: Bearer {{configTokenRequest.access_token}}

### Create seed application: broad setup token for EdOrg-only data
# @name createSeedApplication
POST http://localhost:{{configPort}}/v2/applications
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "vendorId": {{getEdFiVendor.id}},
    "applicationName": "Authorization Demo Seed",
    "claimSetName": "E2E-RelationshipsWithEdOrgsOnlyClaimSet",
    "educationOrganizationIds": [2, 201, 20101, 3, 301, 30101, 255901001, 255901222],
    "dmsInstanceIds": [{{createDmsInstance.id}}]
}

### Create school-only application: authorized only for school 255901001
# @name createSchoolOnlyApplication
POST http://localhost:{{configPort}}/v2/applications
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "vendorId": {{getEdFiVendor.id}},
    "applicationName": "Authorization Demo School Only",
    "claimSetName": "E2E-RelationshipsWithEdOrgsOnlyClaimSet",
    "educationOrganizationIds": [255901001],
    "dmsInstanceIds": [{{createDmsInstance.id}}]
}

### Create wrong-school application: authorized only for school 255901222
# @name createWrongSchoolApplication
POST http://localhost:{{configPort}}/v2/applications
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "vendorId": {{getEdFiVendor.id}},
    "applicationName": "Authorization Demo Wrong School",
    "claimSetName": "E2E-RelationshipsWithEdOrgsOnlyClaimSet",
    "educationOrganizationIds": [255901222],
    "dmsInstanceIds": [{{createDmsInstance.id}}]
}

### Create combined-strategy application: State 2 plus School 30101
# @name createOrInvertedApplication
POST http://localhost:{{configPort}}/v2/applications
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "vendorId": {{getEdFiVendor.id}},
    "applicationName": "Authorization Demo OR Inverted",
    "claimSetName": "E2E-RelationshipsWithEdOrgsOnlyOrInvertedClaimSet",
    "educationOrganizationIds": [2, 30101],
    "dmsInstanceIds": [{{createDmsInstance.id}}]
}

### Create people application: EdFiSandbox with State 3 and LEA 6255901
# @name createPeopleApplication
POST http://localhost:{{configPort}}/v2/applications
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "vendorId": {{getEdFiVendor.id}},
    "applicationName": "Authorization Demo People",
    "claimSetName": "EdFiSandbox",
    "educationOrganizationIds": [3, 6255901],
    "dmsInstanceIds": [{{createDmsInstance.id}}]
}

### Create namespace ns2 application
# @name createNs2Application
POST http://localhost:{{configPort}}/v2/applications
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "vendorId": {{getNs2Vendor.id}},
    "applicationName": "Authorization Demo Namespace NS2",
    "claimSetName": "E2E-NameSpaceBasedClaimSet",
    "educationOrganizationIds": [],
    "dmsInstanceIds": [{{createDmsInstance.id}}]
}

### Create namespace ns3 application
# @name createNs3Application
POST http://localhost:{{configPort}}/v2/applications
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{
    "vendorId": {{getNs3Vendor.id}},
    "applicationName": "Authorization Demo Namespace NS3",
    "claimSetName": "E2E-NameSpaceBasedClaimSet",
    "educationOrganizationIds": [],
    "dmsInstanceIds": [{{createDmsInstance.id}}]
}

### Refresh DMS claim-set metadata before creating demo tokens
POST http://localhost:{{dmsPort}}/management/reload-claimsets
Content-Type: application/json
Authorization: Bearer {{configTokenRequest.access_token}}

{}

### Create seedToken
# @name seedTokenRequest
POST {{tokenUrl}}
Authorization: Basic {{createSeedApplication.key}}:{{createSeedApplication.secret}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials

### Create schoolOnlyToken
# @name schoolOnlyTokenRequest
POST {{tokenUrl}}
Authorization: Basic {{createSchoolOnlyApplication.key}}:{{createSchoolOnlyApplication.secret}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials

### Create wrongSchoolToken
# @name wrongSchoolTokenRequest
POST {{tokenUrl}}
Authorization: Basic {{createWrongSchoolApplication.key}}:{{createWrongSchoolApplication.secret}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials

### Create orInvertedToken
# @name orInvertedTokenRequest
POST {{tokenUrl}}
Authorization: Basic {{createOrInvertedApplication.key}}:{{createOrInvertedApplication.secret}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials

### Create peopleToken
# @name peopleTokenRequest
POST {{tokenUrl}}
Authorization: Basic {{createPeopleApplication.key}}:{{createPeopleApplication.secret}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials

### Create namespaceNs2Token
# @name namespaceNs2TokenRequest
POST {{tokenUrl}}
Authorization: Basic {{createNs2Application.key}}:{{createNs2Application.secret}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials

### Create namespaceNs3Token
# @name namespaceNs3TokenRequest
POST {{tokenUrl}}
Authorization: Basic {{createNs3Application.key}}:{{createNs3Application.secret}}
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials

