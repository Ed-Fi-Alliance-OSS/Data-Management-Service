GET {{postSecondaryEventLocation}}
Authorization: Bearer {{peopleTokenRequest.access_token}}

#
# Live demo starts here.
#

# Section 1: EdOrg Filtering And Total Count
#

### Authorized academic week query with post-authorization paging and count
# Expected: 200, Total-Count: 2, body contains one authorized week because limit=1.
# The week for school 255901222 is filtered out before paging/count.
GET {{discovery.urls.dataManagementApi}}/ed-fi/academicWeeks?totalCount=true&limit=1
Authorization: Bearer {{schoolOnlyTokenRequest.access_token}}

#
# Section 2: EdOrg Write Denial
#

### Try to create an academic week for school 255901001 using a token for school 255901222
# Expected: 403 Authorization Denied.
# Error should mention no relationship between EdOrg claim 255901222 and resource item's SchoolId.
# @name forbiddenAcademicWeekCreate
POST {{discovery.urls.dataManagementApi}}/ed-fi/academicWeeks
Authorization: Bearer {{wrongSchoolTokenRequest.access_token}}
Content-Type: application/json

{
    "weekIdentifier": "post create forbidden",
    "schoolReference": {
        "schoolId": 255901001
    },
    "beginDate": "2023-08-08",
    "endDate": "2023-08-14",
    "totalInstructionalDays": 5
}

### Prove the denied POST did not create a record
# Expected: 200, Total-Count: 0, body [].
GET {{discovery.urls.dataManagementApi}}/ed-fi/academicWeeks?weekIdentifier=post%20create%20forbidden&totalCount=true
Authorization: Bearer {{schoolOnlyTokenRequest.access_token}}

#
# Section 3: Combined Authorization Strategies
#

### GET-many with compatible normal and inverted EdOrg strategies ORed together
# Expected: 200, returns LEA 201 and LEA 301.
# LEA 201 is authorized top-down from State 2.
# LEA 301 is authorized bottom-up from School 30101.
GET {{discovery.urls.dataManagementApi}}/ed-fi/localEducationAgencies
Authorization: Bearer {{orInvertedTokenRequest.access_token}}

#
# Section 4: People Relationship Delete Demo
#

### Before removing the relationship, the PostSecondaryEvent is readable
# Expected: 200.
GET {{discovery.urls.dataManagementApi}}/ed-fi/PostSecondaryEvents/{{getPeoplePostSecondaryEvent.id}}
Authorization: Bearer {{peopleTokenRequest.access_token}}

### Remove the StudentSchoolAssociation relationship
# Expected: 204.
DELETE {{discovery.urls.dataManagementApi}}/ed-fi/studentSchoolAssociations/{{getPeopleStudentSchoolAssociation.id}}
Authorization: Bearer {{peopleTokenRequest.access_token}}

### The resource still exists, but the caller no longer has a student relationship path
# Expected: 403 Authorization Denied.
GET {{discovery.urls.dataManagementApi}}/ed-fi/PostSecondaryEvents/{{getPeoplePostSecondaryEvent.id}}
Authorization: Bearer {{peopleTokenRequest.access_token}}

### Delete is denied for the same reason
# Expected: 403 Authorization Denied.
DELETE {{discovery.urls.dataManagementApi}}/ed-fi/PostSecondaryEvents/{{getPeoplePostSecondaryEvent.id}}
Authorization: Bearer {{peopleTokenRequest.access_token}}

#
# Section 5: Namespace Authorization
#

### Create a descriptor in uri://ns2.org with the ns2 token
# Expected: 200 or 201.
# @name createNamespaceDescriptor
POST {{discovery.urls.dataManagementApi}}/ed-fi/absenceEventCategoryDescriptors
Authorization: Bearer {{namespaceNs2TokenRequest.access_token}}
Content-Type: application/json

{
    "codeValue": "Namespace Based",
    "description": "Namespace Based",
    "effectiveBeginDate": "2024-05-14",
    "effectiveEndDate": "2024-05-14",
    "namespace": "uri://ns2.org/AbsenceEventCategoryDescriptor",
    "shortDescription": "Namespace Based"
