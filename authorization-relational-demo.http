{{
  exports.namespaceDescriptorLocation = response.headers.location;
}}

### Capture the ns2 descriptor id
# @name getNamespaceDescriptorAsNs2
GET {{namespaceDescriptorLocation}}
Authorization: Bearer {{namespaceNs2TokenRequest.access_token}}

### A token limited to uri://ns3.org cannot read the ns2 descriptor by id
# Expected: 403 Authorization Denied.
GET {{discovery.urls.dataManagementApi}}/ed-fi/absenceEventCategoryDescriptors/{{getNamespaceDescriptorAsNs2.id}}
Authorization: Bearer {{namespaceNs3TokenRequest.access_token}}

### Query behavior filters unauthorized namespace data out of the result set
# Expected: 200 with [].
GET {{discovery.urls.dataManagementApi}}/ed-fi/absenceEventCategoryDescriptors?codeValue=Namespace%20Based
Authorization: Bearer {{namespaceNs3TokenRequest.access_token}}
