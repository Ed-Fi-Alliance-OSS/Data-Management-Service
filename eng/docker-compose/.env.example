# -----------------
# Postgres database
# -----------------
POSTGRES_PASSWORD=abcdefgh1!
POSTGRES_DB_NAME=edfi_datamanagementservice
POSTGRES_PORT=5435

# ----------------
# Name of the database template package for setting up initial data
# ----------------
DATABASE_TEMPLATE_PACKAGE=EdFi.Api.Populated.Template.PostgreSql.5.2.0
DMS_IMAGE_TAG=pre

# -----
# Kafka
# -----

# Variables for Kafka UI
KAFKA_PORT=9092
KAFKA_UI_PORT=8088

# Variables for Kafka connect
CONNECT_SOURCE_PORT=8083

# ---
# Identity Provider Configuration
# ---
# KEYCLOAK_OAUTH_TOKEN_ENDPOINT / SELF_CONTAINED_OAUTH_TOKEN_ENDPOINT are the DMS container's
# own /oauth/token proxy target (TokenEndpointModule -> AppSettings__AuthenticationService);
# the proxy calls the identity provider from INSIDE the Docker network, so these must stay
# container-internal hostnames. Host-side tooling (e.g. BulkLoadClient) resolves its own
# host-facing endpoint separately and does not read these keys.
KEYCLOAK_OAUTH_TOKEN_ENDPOINT=http://dms-keycloak:8080/realms/edfi/protocol/openid-connect/token
KEYCLOAK_DMS_JWT_AUTHORITY=http://dms-keycloak:8080/realms/edfi
KEYCLOAK_DMS_JWT_METADATA_ADDRESS=http://dms-keycloak:8080/realms/edfi/.well-known/openid-configuration

SELF_CONTAINED_OAUTH_TOKEN_ENDPOINT=http://ed-fi-api-config:8081/connect/token
SELF_CONTAINED_DMS_JWT_AUTHORITY=http://ed-fi-api-config:8081
SELF_CONTAINED_DMS_JWT_METADATA_ADDRESS=http://ed-fi-api-config:8081/.well-known/openid-configuration

# --------
# Keycloak
# --------

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8045

DMS_DATASTORE_CACHE_EXPIRATION_SECONDS=600
DMS_DATASTORE_CACHE_REFRESH_ENABLED=true
# ---
# DMS
# ---
DMS_HTTP_PORTS=8080
# In-network /oauth/token proxy target; see Identity Provider Configuration above. Container-
# internal regardless of database engine.
OAUTH_TOKEN_ENDPOINT=http://ed-fi-api-config:8081/connect/token
BYPASS_TYPE_COERCION=false
ALLOW_IDENTITY_UPDATE_OVERRIDES=
MAXIMUM_PAGE_SIZE=500
PATH_BASE=api
USE_REVERSE_PROXY_HEADERS=false
# Trusted reverse-proxy sources honored when USE_REVERSE_PROXY_HEADERS=true (comma-separated).
# Leave empty to trust loopback only. Examples: REVERSE_PROXY_KNOWN_PROXIES=10.0.0.5,10.0.0.6
# REVERSE_PROXY_KNOWN_NETWORKS=172.16.0.0/12
REVERSE_PROXY_KNOWN_PROXIES=
REVERSE_PROXY_KNOWN_NETWORKS=
DMS_STARTUP_STATUS_FILE_PATH=/tmp/dms-startup-status.json
USE_API_SCHEMA_PATH=true
API_SCHEMA_PATH=/app/ApiSchema
DMS_ENABLE_MANAGEMENT_ENDPOINTS=false
DMS_ENABLE_CLAIMSET_RELOAD=false
DOMAINS_EXCLUDED_FROM_OPEN_API=

# ---
# Enable Application Reset Endpoint (default false)
DMS_CONFIG_ENABLE_APPLICATION_RESET_ENDPOINT=false
# ---
# Multi-Instance Route Qualifiers (Optional)
# ---
ROUTE_QUALIFIER_SEGMENTS=
# Set ROUTE_QUALIFIER_SEGMENTS to enable multi-instance routing with route qualifiers.
# These segments will be extracted from URLs in the format:
# /{districtId}/{schoolYear}/data/ed-fi/schools
#
# The order matters and should match the URL pattern.
# Using comma-separated format - supports zero or many segments.
# Examples:
#   Two segments: ROUTE_QUALIFIER_SEGMENTS=districtId,schoolYear
#   One segment:  ROUTE_QUALIFIER_SEGMENTS=districtId
#   Disabled:     ROUTE_QUALIFIER_SEGMENTS=
#
# When enabled, each instance must have a corresponding database and route context
# configured in the Configuration Service. See docs/MULTI_INSTANCE_TESTING_GUIDE.md
# for detailed setup instructions.

# JWT Authentication
DMS_JWT_AUTHORITY=http://ed-fi-api-config:8081
DMS_JWT_AUDIENCE=account
DMS_JWT_METADATA_ADDRESS=http://ed-fi-api-config:8081/.well-known/openid-configuration
DMS_JWT_REQUIRE_HTTPS_METADATA=false
DMS_JWT_ROLE_CLAIM_TYPE=http://schemas.microsoft.com/ws/2008/06/identity/claims/role
DMS_JWT_CLIENT_ROLE=dms-client
DMS_JWT_CLOCK_SKEW_SECONDS=30
DMS_JWT_REFRESH_INTERVAL_MINUTES=60
DMS_JWT_AUTOMATIC_REFRESH_INTERVAL_HOURS=24

# INFORMATION, WARNING
LOG_LEVEL=DEBUG

MASK_REQUEST_BODY_IN_LOGS=true
CORRELATION_ID_HEADER=correlationid
DMS_DATASTORE=postgresql

# RepeatableRead, Snapshot
DATABASE_ISOLATION_LEVEL=ReadCommitted

# DATABASE_CONNECTION_STRING_ADMIN allows for alternate credentials with elevated permissions for creating database objects
DATABASE_CONNECTION_STRING_ADMIN=host=dms-postgresql;port=5432;username=postgres;password=${POSTGRES_PASSWORD};database=${POSTGRES_DB_NAME};

# Resilience parameters
FAILURE_RATIO=0.01
SAMPLING_DURATION_SECONDS=10
MINIMUM_THROUGHPUT=2
BREAK_DURATION_SECONDS=30

# DMS connecting to Configuration Service
CONFIG_SERVICE_URL=http://ed-fi-api-config:8081
CONFIG_SERVICE_CLIENT_ID=CMSReadOnlyAccess
CONFIG_SERVICE_CLIENT_SECRET=ValidClientSecret1234567890!Abcd
CONFIG_SERVICE_CLIENT_SCOPE=edfi_admin_api/readonly_access
DMS_CLAIMSETS_CACHE_EXPIRATION_SECONDS=600
DMS_APPLICATION_CONTEXT_CACHE_EXPIRATION_SECONDS=600
DMS_TOKEN_CACHE_EXPIRATION_SECONDS=1500
DMS_PROFILE_CACHE_EXPIRATION_SECONDS=1800
DMS_MULTI_TENANCY=false

# Bootstrap admin client used by configure-local-data-store.ps1 (registers via
# /connect/register) and provision-dms-schema.ps1 (authenticates only). Defaults match the
# historical hard-coded local-dev values; uncomment and override only when the local CMS
# environment uses a different admin client.
# DMS_BOOTSTRAP_ADMIN_CLIENT_ID=dms-instance-admin
# DMS_BOOTSTRAP_ADMIN_CLIENT_SECRET=ValidClientSecret1234567890!Abcd

SCHEMA_PACKAGES='[
  {
    "version": "1.0.332",
    "feedUrl": "https://pkgs.dev.azure.com/ed-fi-alliance/Ed-Fi-Alliance-OSS/_packaging/EdFi/nuget/v3/index.json",
    "name": "EdFi.DataStandard52.ApiSchema"
  },
  {
    "version": "1.0.332",
    "feedUrl": "https://pkgs.dev.azure.com/ed-fi-alliance/Ed-Fi-Alliance-OSS/_packaging/EdFi/nuget/v3/index.json",
    "name": "EdFi.DataStandard52.TPDM.ApiSchema"
  },
  {
    "version": "1.0.332",
    "feedUrl": "https://pkgs.dev.azure.com/ed-fi-alliance/Ed-Fi-Alliance-OSS/_packaging/EdFi/nuget/v3/index.json",
    "name": "EdFi.DataStandard52.Sample.ApiSchema",
    "extensionName": "Sample"
  },
  {
    "version": "1.0.332",
    "feedUrl": "https://pkgs.dev.azure.com/ed-fi-alliance/Ed-Fi-Alliance-OSS/_packaging/EdFi/nuget/v3/index.json",
    "name": "EdFi.DataStandard52.Homograph.ApiSchema",
    "extensionName": "Homograph"
  }
]'

# --------------
# Config Service
# --------------

DMS_CONFIG_ASPNETCORE_HTTP_PORTS=8081
DMS_CONFIG_DATASTORE=postgresql
DMS_CONFIG_DATABASE_CONNECTION_STRING=host=dms-postgresql;port=5432;username=postgres;password=${POSTGRES_PASSWORD};database=${POSTGRES_DB_NAME};
# SQL Server datastore (alternative to PostgreSQL):
# DMS_CONFIG_DATASTORE=mssql
# DMS_CONFIG_DATABASE_CONNECTION_STRING=Server=dms-mssql,1433;Database=edfi_configurationservice;User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=true;
# MSSQL_SA_PASSWORD=abcdefgh1!
# MSSQL_PORT=1435
DMS_CONFIG_DATABASE_ENCRYPTION_KEY=DefaultEncryptionKey32CharactersX1
DMS_CONFIG_IDENTITY_ALLOW_REGISTRATION=true
DMS_CONFIG_IDENTITY_SERVICE_ROLE=cms-client
DMS_CONFIG_IDENTITY_CLIENT_ROLE=dms-client
DMS_CONFIG_IDENTITY_AUTHORITY=${DMS_JWT_AUTHORITY}
DMS_CONFIG_IDENTITY_AUDIENCE=${DMS_JWT_AUDIENCE}
DMS_CONFIG_IDENTITY_CLIENT_ID=DmsConfigurationService
DMS_CONFIG_IDENTITY_CLIENT_SECRET=ValidClientSecret1234567890!Abcd
DMS_CONFIG_IDENTITY_CLIENT_SECRET_MINIMUM_LENGTH=32
DMS_CONFIG_IDENTITY_CLIENT_SECRET_MAXIMUM_LENGTH=128
DMS_CONFIG_IDENTITY_REQUIRE_HTTPS=false
DMS_CONFIG_IDENTITY_ROLE_CLAIM_TYPE=${DMS_JWT_ROLE_CLAIM_TYPE}
DMS_CONFIG_LOG_LEVEL=Information
DMS_CONFIG_DEPLOY_DATABASE=true
DMS_CONFIG_PATH_BASE=config
DMS_CONFIG_USE_REVERSE_PROXY_HEADERS=false
# Trusted reverse-proxy sources honored when DMS_CONFIG_USE_REVERSE_PROXY_HEADERS=true (comma-separated).
# Leave empty to trust loopback only. KnownProxies: exact IPs; KnownNetworks: CIDR ranges.
DMS_CONFIG_REVERSE_PROXY_KNOWN_PROXIES=
DMS_CONFIG_REVERSE_PROXY_KNOWN_NETWORKS=
DMS_CONFIG_TOKEN_TIMEOUT_SECONDS=30
DMS_CONFIG_CLAIMS_SOURCE=Hybrid
DMS_CONFIG_CLAIMS_DIRECTORY=/app/additional-claims
DMS_CONFIG_IDENTITY_ENCRYPTION_KEY=QWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXo0NTY3ODkwMTIz
DMS_CONFIG_IDENTITY_HASHING_ITERATIONS=210000
DMS_CONFIG_IDENTITY_PROVIDER=self-contained
DMS_CONFIG_MULTI_TENANCY=false

# --------------
# DMS Swagger UI
# --------------
DMS_SWAGGER_UI_PORT=8082
DMS_SWAGGER_UI_URL=http://localhost:${DMS_SWAGGER_UI_PORT}
DMS_SWAGGER_UI_ENABLE_CUSTOM_DOMAINS=true
