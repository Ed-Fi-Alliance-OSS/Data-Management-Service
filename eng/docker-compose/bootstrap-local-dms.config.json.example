// bootstrap-local-dms.config.json.example
//
// bootstrap-local-dms.ps1 is the required DMS-916 convenience wrapper for the happy-path
// developer bootstrap flow. It is not optional.
//
// Copy this file to bootstrap-local-dms.config.json (git-ignored) to set personal
// default parameters for the bootstrap phase commands.
//
// The wrapper (bootstrap-local-dms.ps1) forwards only the config file path (-ConfigFile)
// to each phase command. Each phase reads its own relevant keys from this file directly.
// Explicit CLI flags on any phase command always override values from this file.
// Unknown keys are silently ignored by each phase (forward-compatibility).
//
// Keys NOT in this file — supply these directly on the owning phase command:
//   -InfraOnly, -DmsBaseUrl            -> start-local-dms.ps1         (mode-changing; not a stable default)
//   -ApiSchemaPath, -ClaimsDirectoryPath -> schema-prep / claims-prep  (expert mode)
//   -NoDmsInstance                      -> configure-local-dms-instance.ps1  (rerun escape hatch)
//   -Rebuild / -r, -d, -v              -> start-local-dms.ps1         (ephemeral / destructive)
//
// Precedence: CLI flag on the phase > value in this file > built-in default

{
  // ---------------------------------------------------------------------------
  // Extensions
  //   Which named extension packages to stage for this run.
  //   Read by: prepare-dms-schema.ps1, prepare-dms-claims.ps1
  //   Supported values (initial set): "sample", "homograph"
  //   Omit or set to [] for core Ed-Fi only (default).
  // ---------------------------------------------------------------------------
  "Extensions": [],

  // ---------------------------------------------------------------------------
  // IdentityProvider
  //   Identity provider for the Docker stack.
  //   "self-contained" - use the built-in OpenIddict CMS identity path (default).
  //   "keycloak"       - use an external Keycloak container.
  //   Read by: start-local-dms.ps1
  // ---------------------------------------------------------------------------
  "IdentityProvider": "self-contained",

  // ---------------------------------------------------------------------------
  // AddSmokeTestCredentials
  //   Create an EdFiSandbox application and surface its key/secret after
  //   DMS instances are created. Useful for teams that always want smoke-test
  //   credentials ready without invoking a separate credential step.
  //   Read by: configure-local-dms-instance.ps1
  //   Default: false
  // ---------------------------------------------------------------------------
  "AddSmokeTestCredentials": false,

  // ---------------------------------------------------------------------------
  // SchoolYearRange
  //   Create one DMS instance per school year, e.g. "2022-2026".
  //   Format: "YYYY-YYYY" (four-digit years; end >= start).
  //   Leave empty ("") for a single default instance (default).
  //   Read by: configure-local-dms-instance.ps1, load-dms-seed-data.ps1
  // ---------------------------------------------------------------------------
  "SchoolYearRange": "",

  // ---------------------------------------------------------------------------
  // LoadSeedData
  //   Opt in to API-based seed data loading after DMS is healthy.
  //   Read by: load-dms-seed-data.ps1
  //   Default: false
  // ---------------------------------------------------------------------------
  "LoadSeedData": false,

  // ---------------------------------------------------------------------------
  // SeedTemplate
  //   Which built-in seed source to use when LoadSeedData is true.
  //   "Minimal"   - all core descriptor resources plus schoolYearTypes (fast; good for CI).
  //   "Populated" - Minimal plus localEducationAgencies, schools, courses,
  //                 students, and studentSchoolAssociations (full developer environment).
  //   Mutually exclusive with SeedDataPath.
  //   Read by: load-dms-seed-data.ps1
  //   Default: "Minimal"
  // ---------------------------------------------------------------------------
  "SeedTemplate": "Minimal",

  // ---------------------------------------------------------------------------
  // SeedDataPath
  //   Path to a local directory containing custom JSONL seed files.
  //   Use when your team maintains a fixed seed directory rather than the
  //   built-in Ed-Fi packages. Mutually exclusive with SeedTemplate.
  //   Leave empty ("") to use the built-in template selected by SeedTemplate (default).
  //   Read by: load-dms-seed-data.ps1
  // ---------------------------------------------------------------------------
  "SeedDataPath": ""
}

