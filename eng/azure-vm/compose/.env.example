# SPDX-License-Identifier: Apache-2.0
#
# Copy to `.env` and customize. `.env` is git-ignored.
#
# >>> Before deploying to the VM, you MUST change every value marked CHANGEME. <<<
# Generate strong secrets, e.g.:  openssl rand -base64 32
#
# Client secrets must be 32-128 chars with at least one lowercase, uppercase,
# digit, and special character (! @ # $ % ^ & * ( ) - _ = + [ ] { } : ; , . ?).

# ---------------------------------------------------------------------------
# Public address (how the review team reaches the gateway)
# ---------------------------------------------------------------------------
# Local testing:   https://localhost  /  localhost
# Azure VM:        https://<label>.<region>.cloudapp.azure.com  /  <label>.<region>.cloudapp.azure.com
#
# CMS (and the DMS /oauth/token proxy) call https://${PUBLIC_HOST}/auth/... from INSIDE their
# containers; the gateway carries PUBLIC_HOST as a Docker network alias so any real hostname
# resolves in-network and the (possibly self-signed) gateway cert is trusted via SSL_CERT_FILE.
# `localhost` is the one name that alias cannot cover (in-container it is the container itself),
# so use a non-localhost name even locally -- e.g. dms-sec.localtest.me (public DNS for
# 127.0.0.1) or an /etc/hosts entry. The localhost default cannot complete token flows.
PUBLIC_BASE_URL=https://localhost
PUBLIC_HOST=localhost
EXTERNAL_PORT=443
HTTP_PORT=80
HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Container images
# ---------------------------------------------------------------------------
DMS_IMAGE_TAG=pre

# ---------------------------------------------------------------------------
# PostgreSQL (shared by both stacks)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_postgres_pw_1!

# ---------------------------------------------------------------------------
# DMS / CMS behavior
# ---------------------------------------------------------------------------
# DMS data DBs use the relational backend and are provisioned OUT OF BAND (via the
# api-schema-tools tool) -- the DMS never deploys schema on startup. The CMS DBs do deploy
# their schema on startup (AppSettings__DeployDatabaseOnStartup=true on the CMS services).
# Queries are served from PostgreSQL (no Kafka/OpenSearch).
LOG_LEVEL=Information
DMS_CONFIG_LOG_LEVEL=Information
DMS_JWT_AUDIENCE=account
# Multi-tenant route qualifier segments (comma-separated). Drives /mt-dms routing:
#   /mt-dms/<tenant>/<schoolYear>/data/ed-fi/...
ROUTE_QUALIFIER_SEGMENTS=schoolYear

# ---------------------------------------------------------------------------
# Claim sets (authorization for key/secret clients) + management surface
# ---------------------------------------------------------------------------
# Embedded (default) ships E2E-NoFurtherAuthRequiredClaimSet (full access),
# E2E-NameSpaceBasedClaimSet, and E2E-RelationshipsWithEdOrgsOnlyClaimSet (school/district).
# Set Hybrid to ALSO load custom claim set *.json placed in compose/claims/.
# Custom claim sets can also be created at runtime via POST/import /v3/claimSets.
DMS_CONFIG_CLAIMS_SOURCE=Embedded
# Enables the CMS POST /management/reload-claims endpoint, which re-seeds the claim-set
# catalog from the configured source into an already-populated config DB. Leave false for
# the review; flip to true only to refresh claims (e.g. after pulling a newer image), reload,
# then set back to false and recreate the CMS.
DMS_CONFIG_ENABLE_CLAIMS_RELOAD=false
# Opt-in DMS management surface (claim-set reload, etc.) for troubleshooting/iteration.
DMS_ENABLE_MANAGEMENT_ENDPOINTS=false
DMS_ENABLE_CLAIMSET_RELOAD=false

# ---------------------------------------------------------------------------
# Grand Bend sample data
# ---------------------------------------------------------------------------
# Two seeding paths (see docs/infrastructure.md "Provisioning method"):
#   - single-tenant: API bulk-load (ODS BulkLoadClient), or restore a RELATIONAL populated
#     template with seed/grandbend.sh;
#   - multi-tenant : API bulk-load works directly (DMS-1230 fixed in :pre >= 2026-06-24), or
#     seed/clone-data.sh copies the seeded edfi_st into the per-tenant DBs (faster).
#
# seed/grandbend.sh needs a RELATIONAL template build; every EdFi.Api.* build qualifies
# (post DMS-1159, 2026-06-09). The legacy document-store dumps shipped under the retired
# EdFi.Dms.* package ids and are rejected by the relational backend; grandbend.sh guards
# against them. Leave VERSION as "latest" to take the newest build, or pin one.
DATABASE_TEMPLATE_PACKAGE_ID=EdFi.Api.Populated.Template.PostgreSql.5.2.0
DATABASE_TEMPLATE_PACKAGE_VERSION=latest

# ---------------------------------------------------------------------------
# Identity provider (Keycloak-only)
# ---------------------------------------------------------------------------
# This environment wires the DMS/CMS token endpoints, JWT authority, and metadata addresses
# to the shared Keycloak realm; there is no self-contained (OpenIddict) variant here. For
# self-contained identity use the official eng/docker-compose local stack instead.
KEYCLOAK_REALM=edfi
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGEME_kc_admin_1!
KEYCLOAK_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Service client credentials (created in Keycloak by bootstrap.ps1)
# ---------------------------------------------------------------------------
# CMS -> Keycloak admin client (full access). 32-128 chars, complex.
DMS_CONFIG_IDENTITY_CLIENT_ID=DmsConfigurationService
DMS_CONFIG_IDENTITY_CLIENT_SECRET=CHANGEME_FullAccessSecret_123!Abcd

# DMS -> CMS read-only client.
CONFIG_SERVICE_CLIENT_ID=CMSReadOnlyAccess
CONFIG_SERVICE_CLIENT_SCOPE=edfi_admin_api/readonly_access
CONFIG_SERVICE_CLIENT_SECRET=CHANGEME_ReadOnlySecret_12345!Abcd

# ---------------------------------------------------------------------------
# Encryption keys
# ---------------------------------------------------------------------------
# Exactly 32 characters.
DMS_CONFIG_DATABASE_ENCRYPTION_KEY=CHANGEME_32_char_db_enc_key_0001
# Base64 (openssl rand -base64 32).
DMS_CONFIG_IDENTITY_ENCRYPTION_KEY=CHANGEME_base64_identity_key_replace_me=

# ---------------------------------------------------------------------------
# Bootstrap: data-store admin client + tenants (used by bootstrap.ps1)
# ---------------------------------------------------------------------------
BOOTSTRAP_ADMIN_CLIENT_ID=dms-bootstrap-admin
BOOTSTRAP_ADMIN_CLIENT_SECRET=CHANGEME_BootstrapAdmin_123456!Abcd
# Multi-tenant tenant names to create.
MT_TENANT_1=tenant1
MT_TENANT_2=tenant2
# School year context value used for the default multi-tenant data stores.
MT_SCHOOL_YEAR=2025

# ---------------------------------------------------------------------------
# pgAdmin (database access for the review team, reachable at /pgadmin)
# ---------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@example.org
PGADMIN_DEFAULT_PASSWORD=CHANGEME_pgadmin_pw_1!
